# =============================================================================
# @vaquita/admin — Variables de entorno
# =============================================================================
# Uso local: copia este archivo a `.env` y rellena los valores.
#
# En Dokploy las variables se reparten en 3 secciones. Abajo están agrupadas
# igual que en el panel para que las copies a la sección correspondiente.
# =============================================================================


# =============================================================================
# 1) ENVIRONMENT SETTINGS  (runtime)
# =============================================================================
NODE_ENV=production

# Passcode that gates EVERY admin route (enforced by src/middleware.ts). Users
# must enter it at /login to obtain an httpOnly session cookie. SERVER-ONLY (no
# NEXT_PUBLIC_ prefix) → never shipped to the browser. Leave empty to run in
# "open mode" with the gate disabled (dev only).
ADMIN_PASSCODE=


# =============================================================================
# 2) BUILD-TIME ARGUMENTS
# Las NEXT_PUBLIC_* se hornean en el build → SIEMPRE van aquí (no en Environment
# Settings). El Dockerfile las recibe como ARG.
# Requeridas y NO pueden ir vacías (si no, el build falla en el prerender):
#   NEXT_PUBLIC_SERVICES_URL, NEXT_PUBLIC_ABLY_KEY
# =============================================================================
NEXT_PUBLIC_SERVICES_URL=https://api-service.vaquita.fi
NEXT_PUBLIC_ABLY_KEY=
# Sent as `x-admin-secret` on admin write calls (badge CRUD). Must match the
# API's ADMIN_SECRET. Optional: leave empty when the API runs in open dev mode.
NEXT_PUBLIC_ADMIN_SECRET=


# =============================================================================
# 3) BUILD-TIME SECRETS
# Info sensible, solo disponible en build. En el Dockerfile se montan como
# --mount=type=secret,id=<nombre>
# =============================================================================
# notification_webhook_url=
# notification_webhook_token=


# -----------------------------------------------------------------------------
# No usadas actualmente por apps/admin (heredadas del template de apps/web).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
# NEXT_PUBLIC_STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
