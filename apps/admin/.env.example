# =============================================================================
# @vaquita/admin — Variables de entorno
# =============================================================================
# Uso local: copia este archivo a `.env` y rellena los valores.
#
# En Dokploy las variables se reparten en 3 secciones. Abajo están agrupadas
# igual que en el panel para que las copies a la sección correspondiente.
# =============================================================================


# =============================================================================
# 1) ENVIRONMENT SETTINGS  (runtime)
# =============================================================================
NODE_ENV=production

# Pooled Postgres connection (port 6543, needs ?pgbouncer=true). Required: the
# server-side admin routes (e.g. /api/admin/tokens, /api/config) query Postgres
# directly via the shared @vaquita/db Prisma client. Use the SAME value as
# apps/api — if unset, those routes fail with a 500.
DATABASE_URL=postgresql://postgres.<tenant>:<password>@<host>:6543/postgres?pgbouncer=true

# Server-side secret that gates the local admin API routes (/api/config,
# /api/admin/tokens). Mirrors the API's ADMIN_SECRET "open when unset" contract:
# if set, those routes require the matching x-admin-secret header; if empty they
# run open (dev only). SERVER-ONLY (no NEXT_PUBLIC_ prefix). Use the SAME value
# as apps/api and as NEXT_PUBLIC_ADMIN_SECRET below.
ADMIN_SECRET=

# Passcode that gates EVERY admin route (enforced by src/middleware.ts). Users
# must enter it at /login to obtain an httpOnly session cookie. SERVER-ONLY (no
# NEXT_PUBLIC_ prefix) → never shipped to the browser. Leave empty to run in
# "open mode" with the gate disabled (dev only).
ADMIN_PASSCODE=

# Soroban RPC endpoint used by POST /api/admin/contract-events to scan the pool
# contract's deposit/withdraw events in a date range. SERVER-ONLY. Optional: if
# empty it defaults by network — mainnet RPC when the Config network passphrase
# is PUBLIC, otherwise the public testnet RPC. Note RPC only retains a few days
# of events, so old date ranges return a warning and are clamped.
SOROBAN_RPC_URL=


# =============================================================================
# 2) BUILD-TIME ARGUMENTS
# Las NEXT_PUBLIC_* se hornean en el build → SIEMPRE van aquí (no en Environment
# Settings). El Dockerfile las recibe como ARG.
# Requeridas y NO pueden ir vacías (si no, el build falla en el prerender):
#   NEXT_PUBLIC_SERVICES_URL
# Ably ya NO necesita key en el cliente: usa token-auth contra
# `GET ${NEXT_PUBLIC_SERVICES_URL}/api/v1/ably/admin-token` (gated por el
# admin-secret; la key de Ably vive en la API).
# =============================================================================
NEXT_PUBLIC_SERVICES_URL=https://api-service.vaquita.fi
# Sent as `x-admin-secret` on admin write calls (badge CRUD) and on the Ably
# token request. Must match the API's ADMIN_SECRET. Optional: leave empty when
# the API runs in open dev mode.
NEXT_PUBLIC_ADMIN_SECRET=


# =============================================================================
# 3) BUILD-TIME SECRETS
# Info sensible, solo disponible en build. En el Dockerfile se montan como
# --mount=type=secret,id=<nombre>
# =============================================================================
# notification_webhook_url=
# notification_webhook_token=


# -----------------------------------------------------------------------------
# No usadas actualmente por apps/admin (heredadas del template de apps/web).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
# NEXT_PUBLIC_STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
