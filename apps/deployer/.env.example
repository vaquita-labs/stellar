# All of these are expected to be injected by `doppler run --config <env>`.
# This file is only a reference for local testing without Doppler.

# --- DeFindex API ---
DEFINDEX_API_KEY=sk_...
DEFINDEX_API_URL=https://api.defindex.io

# --- Deployer keypair (signs the XDR locally) ---
DEPLOYER_SECRET_KEY=S...
DEPLOYER_PUBLIC_KEY=G...

# --- Vault roles ---
EMERGENCY_MANAGER_ADDRESS=G...
VAULT_FEE_RECEIVER_ADDRESS=G...
MANAGER_ADDRESS=G...
REBALANCE_MANAGER_ADDRESS=G...

# --- Vault config ---
VAULT_NAME=My USDC Vault
VAULT_SYMBOL=mUSDC
VAULT_FEE_BPS=1000
VAULT_UPGRADABLE=true
NETWORK=testnet

# --- Already-deployed addresses (PaltaLabs / Soroswap) ---
BLEND_USDC_STRATEGY_ADDRESS=C...
BLEND_USDC_STRATEGY_NAME=blend_usdc
USDC_CONTRACT_ADDRESS=C...
SOROSWAP_ROUTER_ADDRESS=C...

# Mainnet Blend USDC strategy:
# BLEND_USDC_STRATEGY_ADDRESS=CDB2WMKQQNVZMEBY7Q7GZ5C7E7IAFSNMZ7GGVD6WKTCEWK7XOIAVZSAP
# BLEND_USDC_STRATEGY_NAME=blend_usdc_autocompound_fixed_strategy

# --- Output (written back by this script; not required to be set beforehand) ---
# VAULT_ID=C...

# --- CI / guarded workflow controls ---
# DEPLOYMENT_ENVIRONMENT=mainnet
# DEPLOYER_VALIDATE_ONLY=true
# DEPLOYMENT_ARTIFACT_PATH=artifacts/defindex-vault-mainnet.json
# WRITE_VAULT_ID_TO_DOPPLER=false
