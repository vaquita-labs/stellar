{
  "name": "@vaquita/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app-api.ts",
    "start": "tsx src/app-api.ts",
    "reconcile:devnet": "tsx src/scripts/reconcile.ts",
    "reconcile:mainnet": "tsx src/scripts/reconcile.ts",
    "reconcile:testnet": "tsx src/scripts/reconcile.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "@vaquita/db": "workspace:*",
    "@vaquita/shared": "workspace:*",
    "ably": "^2.21.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
