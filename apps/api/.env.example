# =============================================================================
# @vaquita/api — Variables de entorno
# =============================================================================
# Uso local: copia este archivo a `.env` y rellena los valores.
#
# En Dokploy las variables se reparten en 3 secciones. Abajo están agrupadas
# igual que en el panel para que las copies a la sección correspondiente.
# =============================================================================


# =============================================================================
# 1) ENVIRONMENT SETTINGS  (runtime)
# =============================================================================
NODE_ENV=production
PORT=3100

# Pooled Postgres connection (port 6543, needs ?pgbouncer=true). Consumed by the
# shared @vaquita/db Prisma client. Required — the app exits on startup if unset.
DATABASE_URL=postgresql://postgres.<tenant>:<password>@<host>:6543/postgres?pgbouncer=true

# Admin API secret. If set, admin endpoints require the matching x-admin-secret
# header; if empty they run open (dev only).
ADMIN_SECRET=

# Log level. Defaults to "info" in production, "debug" otherwise.
LOG_LEVEL=

# Realtime (Ably) FULL key (appId.keyId:secret). Server-only: the web/admin
# clients never see it — they request short-lived tokens from
# GET /api/v1/ably/token.
ABLY_KEY=

# ---- Stellar / badges -------------------------------------------------------
# Network label (e.g. "Testnet", "Mainnet").
STELLAR_NETWORK=Testnet

# Network passphrase. Defaults to Testnet if unset.
STELLAR_NETWORK_PASSPHRASE=

# Optional Soroban RPC overrides (default to the public endpoints).
STELLAR_TESTNET_SOROBAN_RPC=
STELLAR_MAINNET_SOROBAN_RPC=

# Badge signing key: 64-char hex (32-byte raw Ed25519 seed).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BADGE_SIGNING_SEED=

# Stellar mainnet launch timestamp (Unix ms).
# Generate: node -e "console.log(Date.parse('2026-06-01T00:00:00Z'))"
MAINNET_LAUNCH_TIMESTAMP=

# ---- MinIO avatar storage (S3-compatible) -----------------------------------
# Profile photos are uploaded to MinIO. If these are unset, photo upload returns
# 503 and the rest of the app keeps working.
#
# Endpoint the API uses to reach MinIO. On Dokploy use the INTERNAL service URL
# (e.g. http://minio:9000); locally, http://localhost:9000.
MINIO_ENDPOINT=
# Public base URL browsers use to GET avatars — the PUBLIC Dokploy domain for the
# MinIO S3 API (e.g. https://minio.yourdomain.com). Falls back to MINIO_ENDPOINT.
MINIO_PUBLIC_URL=
# Credentials (MinIO root user/password or a scoped access key pair).
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Bucket name (created automatically with a public-read policy). Default: avatars.
MINIO_BUCKET=avatars
# Region label — any value works for MinIO. Default: us-east-1.
MINIO_REGION=us-east-1

# ---- DeFindex ---------------------------------------------------------------
DEFINDEX_API_HOST=
DEFINDEX_API_KEY=

# ---- Deploy webhook (optional) ----------------------------------------------
# Same values as the build-time secrets in section 3. Read by the deploy
# notification flow.
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TOKEN=


# =============================================================================
# 2) BUILD-TIME ARGUMENTS
# El Dockerfile las recibe como ARG. Configúralas en el panel, NO en este file.
# =============================================================================
# DEPLOY_ID
# WEBHOOK_SOURCE             (defaults to "apps/api")


# =============================================================================
# 3) BUILD-TIME SECRETS
# Info sensible, solo disponible en build. En el Dockerfile se montan como
# --mount=type=secret,id=<nombre>
# =============================================================================
# notification_webhook_url=
# notification_webhook_token=
