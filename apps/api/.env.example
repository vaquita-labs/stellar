PORT=3000

# Admin API secret (X-Admin-Secret header). If unset, admin endpoints are open (dev only).
ADMIN_SECRET=
NODE_ENV=production

SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=abc.xyz.123

PRIVATE_KEY=0x123

ABLY_KEY=abc

# DeFindex HTTP API (7d vault APY): GET {DEFINDEX_API_HOST}/vault/{address}/apy?network=testnet|mainnet
DEFINDEX_API_HOST=
DEFINDEX_API_KEY=

# Optional override for Stellar mainnet Soroban RPC (defaults to public endpoint in shared)
STELLAR_MAINNET_SOROBAN_RPC=

# Badge signing key: 64-char hex string (32-byte raw Ed25519 seed).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The matching public key (for contract initialize) is derived automatically.
BADGE_SIGNING_SEED=

# Mainnet Pioneer (D2): Unix timestamp in milliseconds of the Stellar mainnet launch moment.
# Set this when mainnet goes live. Wallets that deposit within 7 days of this timestamp qualify.
# Generate: node -e "console.log(Date.parse('2026-06-01T00:00:00Z'))"
MAINNET_LAUNCH_TIMESTAMP=

# Optional: override Stellar testnet Soroban RPC (defaults to soroban-testnet.stellar.org).
STELLAR_TESTNET_SOROBAN_RPC=

# Optional: Stellar network label used in badge metadata (e.g. "Testnet", "Mainnet").
STELLAR_NETWORK=Testnet

# CYCLE_DURATION_MS=900000   # test only: override monthly cycle (900000 = 15 min)
