# =============================================================================
# apps/api — environment variables
# Tags map to the Dokploy panel:
#   [ENV]    → "Environment Settings"  — runtime
#   [ARG]    → "Build-time Arguments"  — build only
#   [SECRET] → "Build-time Secrets"    — build only, sensitive
# =============================================================================

# ---- [ENV] Required ---------------------------------------------------------
NODE_ENV=production
PORT=3100

# Supabase
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=abc.xyz.123

# Pooled Postgres connection (port 6543). Needs ?pgbouncer=true.
DATABASE_URL=postgresql://postgres.<tenant>:<password>@<host>:6543/postgres?pgbouncer=true

# ---- [ENV] Optional ---------------------------------------------------------
# Admin API secret. If unset, admin endpoints are open (dev only).
ADMIN_SECRET=

# Log level. Defaults to "info" in production, "debug" otherwise.
LOG_LEVEL=

# Realtime (Ably) key.
ABLY_KEY=abc

# ---- [ENV] Stellar / badges -------------------------------------------------
# Network label (e.g. "Testnet", "Mainnet").
STELLAR_NETWORK=Testnet

# Network passphrase. Defaults to Testnet if unset.
STELLAR_NETWORK_PASSPHRASE=

# Optional Soroban RPC overrides (default to the public endpoints).
STELLAR_TESTNET_SOROBAN_RPC=
STELLAR_MAINNET_SOROBAN_RPC=

# Badge signing key: 64-char hex (32-byte raw Ed25519 seed).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BADGE_SIGNING_SEED=

# Stellar mainnet launch timestamp (Unix ms).
# Generate: node -e "console.log(Date.parse('2026-06-01T00:00:00Z'))"
MAINNET_LAUNCH_TIMESTAMP=

# ---- [ENV] DeFindex ---------------------------------------------------------
DEFINDEX_API_HOST=
DEFINDEX_API_KEY=

# ---- [ENV] Deploy webhook (optional) ----------------------------------------
# Same values as the build-time [SECRET]s below.
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TOKEN=

# ---- [ENV] Test only --------------------------------------------------------
# Override the cycle duration in ms (900000 = 15 min). Leave unset in prod.
# CYCLE_DURATION_MS=900000

# =============================================================================
# Build-time only — set these in the Dokploy panel, NOT in this file:
#   [ARG]    DEPLOY_ID
#   [ARG]    WEBHOOK_SOURCE             (defaults to "apps/api")
#   [SECRET] notification_webhook_url
#   [SECRET] notification_webhook_token
# =============================================================================