# Postgres connection strings from Supabase → Project Settings → Database.
#
# DATABASE_URL — pooled connection (Supavisor / pgbouncer), port 6543. Used at
# runtime by the app. The `?pgbouncer=true` flag is required so Prisma disables
# prepared statements (pgbouncer transaction mode does not support them).
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL — direct connection, port 5432. Used by `prisma db pull` and any
# introspection/migration tooling (the pooler can't run those reliably).
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"
